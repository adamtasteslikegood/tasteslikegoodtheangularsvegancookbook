# Environment Configuration Example
# Copy this file to .env.local and fill in actual values

# Node environment (development, production)
NODE_ENV=development

# Server port
PORT=8080

# Google Gemini API Key (required)
# Get this from: https://ai.google.dev/
GEMINI_API_KEY=your-gemini-api-key-here

# Legacy API key variables (deprecated, use GEMINI_API_KEY instead)
# VITE_GEMINI_API_KEY=your-gemini-api-key-here
# VITE_API_KEY=your-api-key-here

# Flask backend URL for auth proxy (default: http://localhost:5000)
# Express proxies /api/auth/* to this URL so the browser only talks to Express.
FLASK_BACKEND_URL=http://localhost:5000

# Frontend URL (for CORS configuration when implemented)
FRONTEND_URL=http://localhost:8080

# Optional: API authentication key for endpoints (when implemented)
# API_KEY=your-secure-random-api-key

# Optional: Database URL (when database is added)
# DATABASE_URL=your-database-connection-string

# Optional: Logging level (error, warn, info, debug)
# LOG_LEVEL=info

# Optional: Enable detailed request logging
# DEBUG=true

# Atlassian PM/session sync (Jira + Confluence)
# Official workflow:
# - KAN = active execution board (who is working on what right now)
# - RCP = delivery board (epics, sprints, scope, acceptance)
# - Confluence = durable planning/session history and docs
# Start sessions with `npm run pm:start`, publish docs with `npm run pm:sync`,
# and inspect live status with `npm run pm:status`.
# Store real values in .env only. Never commit real Atlassian tokens.
ATLASSIAN_URL=tasteslikegood.atlassian.net
# ATLASSIAN_EMAIL=your-atlassian-email@example.com
# ATLASSIAN_API_TOKEN=your-atlassian-api-token
ATLASSIAN_JIRA_PROJECT_KEY=KAN
ATLASSIAN_JIRA_DELIVERY_PROJECT_KEY=RCP
# Optional explicit override for status scripts; defaults to KAN,RCP when unset.
# JIRA_PROJECTS=KAN,RCP
ATLASSIAN_CONFLUENCE_SPACE_KEY=TLG
ATLASSIAN_CONFLUENCE_SPACE_ID=11042818
ATLASSIAN_CONFLUENCE_PARENT_PAGE_ID=11796481
# Optional: separate parent for per-session Confluence log pages created by the
# session-log tooling (pm_daemon log_agent_session; publish_session_log.py, used
# by the pi agent and other coding agents).
# Defaults to ATLASSIAN_CONFLUENCE_PARENT_PAGE_ID when unset.
# Alias: CONFLUENCE_SESSION_LOGS_PARENT_ID (the prefixed name wins if both are set).
# 34635777 = "Agent Session Logs" index page in the TLG space (coding-agent
# logs; the separate "AI Session Logs" page 29884418 is for Rovo sessions).
# ATLASSIAN_CONFLUENCE_SESSION_LOG_PARENT_PAGE_ID=34635777
ATLASSIAN_CONFLUENCE_BRIEFING_TITLE=Project PM Briefing - Live State

# GCP monitoring MCP server (scripts/monitoring/gcp_mcp_server.py)
# Read-only service-account key (roles/monitoring.viewer). Keep the key file
# OUTSIDE the repo and set real values in .env only — never commit a key.
# See docs/MCP_GCP_MONITORING.md for setup.
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/monitoring-viewer.json
# GCP_PROJECT_ID=comdottasteslikegood
