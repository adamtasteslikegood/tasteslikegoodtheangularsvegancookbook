{
  "enabledMcpjsonServers": [
    "pm-daemon",
    "gcp-monitor"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/check-gstack.sh"
          }
        ]
      },
      {
        "matcher": "mcp__plugin_github_github__(add_reply_to_pull_request_comment|add_comment_to_pending_review|add_issue_comment|pull_request_review_write)",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pretooluse-pr-review-nudge.sh",
            "statusMessage": "Checking PR-review skill"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pretooluse-pr-review-nudge.sh",
            "if": "Bash(gh *)",
            "statusMessage": "Checking PR-review skill"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/precompact-session-log.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/sessionstart-git-sync.sh",
            "timeout": 90,
            "statusMessage": "Syncing git + checking divergence"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/sessionstart-pm-briefing.sh",
            "timeout": 15,
            "statusMessage": "Loading PM briefing"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/sessionend-session-log.sh",
            "timeout": 15,
            "statusMessage": "Capturing session log"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "engineering-skills@claude-code-skills": true,
    "engineering-advanced-skills@claude-code-skills": true,
    "marketing-skills@claude-code-skills": true,
    "pm-skills@claude-code-skills": true,
    "product-skills@claude-code-skills": true,
    "c-level-skills@claude-code-skills": true,
    "ra-qm-skills@claude-code-skills": true,
    "business-growth-skills@claude-code-skills": true,
    "finance-skills@claude-code-skills": true,
    "code-review@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true
  }
}
