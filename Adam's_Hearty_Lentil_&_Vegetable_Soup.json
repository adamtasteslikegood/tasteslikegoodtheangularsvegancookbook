  "instructions": [
    {
      "description": "Heat the olive oil in a large pot or Dutch oven over medium heat. Add the diced onion, carrots, and celery (the mirepoix) and cook, stirring occasionally, until softened, about 5-7 minutes.",
      "step": 1
    },
    {
      "description": "Add the minced garlic and cook for another minute until fragrant.",
      "step": 2
    },
    {
      "description": "Stir in the rinsed lentils, dried thyme, and dried rosemary. Cook for one minute, stirring constantly, to toast the spices.",
      "step": 3
    },
    {
      "description": "Pour in the vegetable broth and the can of diced tomatoes (with their juice). Add the bay leaf. Bring the soup to a boil.",
      "step": 4
    },
    {
      "description": "Once boiling, reduce the heat to low, cover, and let it simmer for 30-35 minutes, or until the lentils are tender.",
      "step": 5
    },
    {
      "description": "Remove the pot from the heat and discard the bay leaf. Stir in the fresh spinach and lemon juice. The residual heat will wilt the spinach perfectly.",
      "step": 6
    },
    {
      "description": "Season with salt and pepper to your taste. Serve hot, garnished with fresh parsley if desired.",
      "step": 7
    }
