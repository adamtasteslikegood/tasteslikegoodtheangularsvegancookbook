{
  "name": "vegangenius-chef",
  "private": true,
  "version": "0.2.5",
  "type": "module",
  "scripts": {
    "dev": "ng serve",
    "build": "ng build && tsc -p server/tsconfig.server.json",
    "preview": "ng serve --configuration=production",
    "start": "node server/dist/index.js",
    "test": "vitest",
    "test:ci": "vitest run --coverage",
    "test:watch": "vitest watch",
    "lint": "eslint \"src/**/*.ts\" \"server/**/*.ts\" --max-warnings 0",
    "lint:fix": "eslint \"src/**/*.ts\" \"server/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.{ts,html,css,json}\" \"server/**/*.ts\" \"*.{js,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,css,json}\" \"server/**/*.ts\" \"*.{js,json,md}\"",
    "type-check": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p server/tsconfig.server.json"
  },
  "dependencies": {
    "@angular/build": "22.0.5",
    "@angular/cli": "22.0.5",
    "@angular/common": "22.0.5",
    "@angular/compiler": "22.0.5",
    "@angular/compiler-cli": "22.0.5",
    "@angular/core": "22.0.5",
    "@angular/forms": "22.0.5",
    "@angular/platform-browser": "22.0.5",
    "@google-cloud/secret-manager": "^6.1.1",
    "@google/genai": "^1.50.1",
    "autoprefixer": "^10.5.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "google-auth-library": "^10.9.0",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "rate-limit-redis": "^4.3.1",
    "rxjs": "^7.8.2",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@angular-eslint/builder": "22.0.0",
    "@angular-eslint/eslint-plugin": "22.0.0",
    "@angular-eslint/eslint-plugin-template": "22.0.0",
    "@angular-eslint/schematics": "22.0.0",
    "@angular-eslint/template-parser": "22.0.0",
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^6.0.0",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.5.0",
    "prettier": "^3.9.4",
    "typescript": "6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.0.8"
  }
}
