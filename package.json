{
  "name": "vegangenius-chef",
  "private": true,
  "version": "0.4.0",
  "type": "module",
  "scripts": {
    "dev": "ng serve",
    "build": "ng build && tsc -p server/tsconfig.server.json",
    "preview": "ng serve --configuration=production",
    "start": "node server/dist/index.js",
    "test": "vitest",
    "test:ci": "vitest run --coverage",
    "test:watch": "vitest watch",
    "pm:start": "npm run pm:check && npm run pm:brief",
    "pm:check": "python3 scripts/pm/atlassian_pm_link.py check",
    "pm:brief": "python3 scripts/pm/atlassian_pm_link.py brief",
    "pm:reflect": "python3 scripts/pm/atlassian_pm_link.py reflect",
    "pm:sync": "python3 scripts/pm/atlassian_pm_link.py sync",
    "pm:publish": "npm run pm:sync",
    "pm:status": "bash scripts/pm/run_pm_script.sh sync_jira_confluence_status.py",
    "pm:daemon": "npm run pm:daemon:start",
    "pm:daemon:start": "bash scripts/pm/daemon_control.sh start",
    "pm:daemon:stop": "bash scripts/pm/daemon_control.sh stop",
    "pm:daemon:status": "bash scripts/pm/daemon_control.sh status",
    "pm:daemon:logs": "bash scripts/pm/daemon_control.sh logs",
    "pm:daemon:foreground": "bash scripts/pm/run_pm_daemon.sh --watch-only",
    "lint": "eslint \"src/**/*.ts\" \"server/**/*.ts\" --max-warnings 0",
    "lint:fix": "eslint \"src/**/*.ts\" \"server/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.{ts,html,css,json}\" \"server/**/*.ts\" \"*.{js,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,css,json}\" \"server/**/*.ts\" \"*.{js,json,md}\"",
    "type-check": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p server/tsconfig.server.json"
  },
  "dependencies": {
    "@angular/build": "22.0.7",
    "@angular/cli": "22.0.7",
    "@angular/common": "22.0.7",
    "@angular/compiler": "22.0.7",
    "@angular/compiler-cli": "22.0.7",
    "@angular/core": "22.0.7",
    "@angular/forms": "22.0.7",
    "@angular/platform-browser": "22.0.7",
    "@google-cloud/secret-manager": "^6.2.0",
    "autoprefixer": "^10.5.4",
    "dd-trace": "^6.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.6.0",
    "express-validator": "^7.3.2",
    "google-auth-library": "^10.9.0",
    "helmet": "^8.3.0",
    "ioredis": "^5.11.1",
    "rate-limit-redis": "^5.0.0",
    "rxjs": "^7.8.2",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@angular-eslint/builder": "22.1.0",
    "@angular-eslint/eslint-plugin": "22.1.0",
    "@angular-eslint/eslint-plugin-template": "22.1.0",
    "@angular-eslint/schematics": "22.1.0",
    "@angular-eslint/template-parser": "22.1.0",
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "typescript": "6.0.3",
    "vite": "^8.1.5",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "hono": "4.12.26"
  }
}
