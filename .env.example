# Environment Configuration Example
# Copy this file to .env.local and fill in actual values

# Node environment (development, production)
NODE_ENV=development

# Server port
PORT=8080

# Google Gemini API Key (required)
# Get this from: https://ai.google.dev/
GEMINI_API_KEY=your-gemini-api-key-here

# Legacy API key variables (deprecated, use GEMINI_API_KEY instead)
# VITE_GEMINI_API_KEY=your-gemini-api-key-here
# VITE_API_KEY=your-api-key-here

# Flask backend URL for auth proxy (default: http://localhost:5000)
# Express proxies /api/auth/* to this URL so the browser only talks to Express.
FLASK_BACKEND_URL=http://localhost:5000

# Frontend URL (for CORS configuration when implemented)
FRONTEND_URL=http://localhost:8080

# Optional: API authentication key for endpoints (when implemented)
# API_KEY=your-secure-random-api-key

# Optional: Database URL (when database is added)
# DATABASE_URL=your-database-connection-string

# Optional: Logging level (error, warn, info, debug)
# LOG_LEVEL=info

# Optional: Enable detailed request logging
# DEBUG=true

# Atlassian PM/session sync (Jira + Confluence)
# Used by `npm run pm:check`, `npm run pm:brief`, and `npm run pm:sync`.
# Store real values in .env only. Never commit real Atlassian tokens.
ATLASSIAN_URL=tasteslikegood.atlassian.net
# ATLASSIAN_EMAIL=your-atlassian-email@example.com
# ATLASSIAN_API_TOKEN=your-atlassian-api-token
ATLASSIAN_JIRA_PROJECT_KEY=KAN
ATLASSIAN_CONFLUENCE_SPACE_KEY=TLG
ATLASSIAN_CONFLUENCE_SPACE_ID=11042818
ATLASSIAN_CONFLUENCE_PARENT_PAGE_ID=11796481
ATLASSIAN_CONFLUENCE_BRIEFING_TITLE=Project PM Briefing - Live State
